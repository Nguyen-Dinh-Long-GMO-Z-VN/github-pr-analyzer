# GitHub Personal Access Token
# Get yours at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos only)
GITHUB_TOKEN=ghp_your_token_here

# ============================================
# AI Pull Request Detection Configuration
# ============================================

# Enable/disable AI PR detection (true/false)
# Set to "false" if your project doesn't use AI-generated PRs
AI_DETECTION_ENABLED=true

# Branch prefixes that indicate AI-generated PRs
# Comma-separated list (case-insensitive)
# Examples: claude/, ai/, gpt/, copilot/
AI_BRANCH_PREFIXES=claude/,ai/,gpt/,copilot/

# Author patterns that indicate AI-generated PRs
# Comma-separated list (substring match, case-insensitive)
# Examples: devin-ai-integration, github-copilot, claude-bot
AI_AUTHOR_PATTERNS=devin-ai-integration,github-copilot,claude-bot
